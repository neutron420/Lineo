# Server Configuration
ENV=development
PORT=8080

# Database Configuration (Neon or local PG)
# Example: postgresql://user:password@host:port/dbname?sslmode=require
DATABASE_URL=
DATABASE_URL_FILE=

# Redis Cache for Real-time Ops
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_HOST_FILE=
REDIS_PORT_FILE=
REDIS_PASSWORD_FILE=
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_URL_FILE=

# Security
JWT_SECRET=your_super_secret_jwt_key_here
JWT_SECRET_FILE=
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# SMS Integration (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_ACCOUNT_SID_FILE=
TWILIO_AUTH_TOKEN_FILE=
TWILIO_PHONE_NUMBER_FILE=

# Google Maps/Places APIs
GOOGLE_API_KEY=
GOOGLE_API_KEY_FILE=

# Cloudflare Turnstile (Captcha)
TURNSTILE_SECRET_KEY=
TURNSTILE_SECRET_KEY_FILE=

# Cloudflare R2 Storage (Document Uploads)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET_NAME=queueless-docs

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_KEY_ID_FILE=
RAZORPAY_KEY_SECRET_FILE=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_WEBHOOK_SECRET_FILE=
