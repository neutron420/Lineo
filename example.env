# Server Configuration
ENV=development
PORT=8080

# Database Configuration (Neon or local PG)
# Example: postgresql://user:password@host:port/dbname?sslmode=require
DATABASE_URL=

# Redis Cache for Real-time Ops
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Security
JWT_SECRET=your_super_secret_jwt_key_here

# SMS Integration (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Google Maps/Places APIs
GOOGLE_API_KEY=

# Cloudflare Turnstile (Captcha)
TURNSTILE_SECRET_KEY=

# Cloudflare R2 Storage (Document Uploads)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET_NAME=queueless-docs
